# ─── Project X Backend Configuration ───
# Copy this file to .env and fill in your values

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:Theabsoluteone@projectx.li2i5kg.mongodb.net/?

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# QR Code signing
QR_SECRET=your_qr_signing_secret_here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Stripe Payment Integration ───
# Leave empty to use mock payments (default).
# Register at https://dashboard.stripe.com/register to get your keys.
# Use TEST keys (sk_test_... / pk_test_...) during development.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
